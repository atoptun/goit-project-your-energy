{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite: run dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "editor-browser",
      "request": "launch",
      "name": "Vite: Inside VS Code",
      "url": "http://127.0.0.1:5173/goit-advancedjs-fp-03/",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "smartStep": true,
      "trace": true
      //   "sourceMapPathOverrides": {
      //     "/src/*": "${workspaceFolder}/src/*",
      //     "src/*": "${workspaceFolder}/src/*",
      //     "/*": "${workspaceFolder}/*"
      //   }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Vite: Chrome",
      "url": "http://localhost:5173/goit-advancedjs-fp-03/",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "smartStep": true,
      "trace": true
    }
  ]
}
